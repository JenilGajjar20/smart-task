{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A user-created task with priority, due date, status, category, and reminder settings.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The Firebase Authentication UID of the owner."
        },
        "title": {
          "type": "string",
          "description": "The title of the task. Max 100 chars."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the task."
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "The priority level of the task."
        },
        "category": {
          "type": "string",
          "description": "The category context of the task, can be a default or custom category."
        },
        "overdueEmailSent": {
          "type": "boolean",
          "description": "True if an email has been sent to the user notifying them that this task is overdue."
        },
        "completed": {
          "type": "boolean",
          "description": "Completion status of the task."
        },
        "dueDate": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp for when the task is due."
        },
        "reminderTime": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp for an optional set reminder alert."
        },
        "recurrence": {
          "type": "object",
          "description": "Recurrence settings for repeating tasks.",
          "properties": {
            "frequency": {
              "type": "string",
              "enum": ["none", "daily", "weekly", "monthly", "custom"]
            },
            "interval": {
              "type": "number"
            },
            "unit": {
              "type": "string",
              "enum": ["days", "weeks", "months"]
            }
          },
          "required": ["frequency"]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of task creation."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of last task update."
        },
        "project": {
          "type": "string",
          "description": "Optional custom project categorization name. Max 100 characters."
        }
      },
      "required": ["userId", "title", "priority", "category", "completed", "dueDate", "createdAt", "updatedAt"]
    },
    "WorkspaceSettings": {
      "title": "WorkspaceSettings",
      "description": "User-specific workspace preferences and profiles.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The Firebase Authentication UID of the owner."
        },
        "theme": {
          "type": "string",
          "description": "Selected visual theme."
        },
        "darkMode": {
          "type": "boolean",
          "description": "Contrast mode preference."
        },
        "profileNickname": {
          "type": "string",
          "description": "User's display brand or name."
        },
        "profileRole": {
          "type": "string",
          "description": "Professional or vocational role."
        },
        "profileStation": {
          "type": "string",
          "description": "Workspace hub assignment."
        },
        "defaultCategory": {
          "type": "string",
          "description": "Standard category assigned to new tasks."
        },
        "defaultPriority": {
          "type": "string",
          "description": "Standard priority assigned to new tasks."
        },
        "timeFormat": {
          "type": "string",
          "description": "Clock display setting (12h/24h)."
        },
        "deskSounds": {
          "type": "boolean",
          "description": "Whether chimes are enabled."
        }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "All tasks stored securely under a random document ID."
    },
    "settings/{userId}": {
      "schema": "WorkspaceSettings",
      "description": "User-specific settings stored securely under their UID."
    }
  }
}
