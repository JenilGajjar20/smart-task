rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net Default-Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Task entity validation ---
    function isValidTask(task) {
      return task.keys().hasAll(['userId', 'title', 'priority', 'category', 'completed', 'dueDate']) &&
             task.keys().hasOnly(['userId', 'title', 'priority', 'category', 'completed', 'dueDate', 'createdAt', 'updatedAt', 'description', 'project', 'reminderTime', 'recurrence', 'subtasks', 'estimatedTime', 'notes', 'amount', 'paymentStatus', 'recurringBill', 'habitType', 'streak', 'shoppingQuantity', 'shoppingStore', 'shoppingCost', 'subject', 'studyDuration', 'resourceLink', 'dependency', 'estimatedEffort', 'status', 'attachments', 'overdueEmailSent']) &&
             task.keys().size() >= 6 && task.keys().size() <= 64 &&
             task.userId == request.auth.uid &&
             task.title is string && task.title.size() >= 1 && task.title.size() <= 100 &&
             task.priority is string && (task.priority == 'low' || task.priority == 'medium' || task.priority == 'high') &&
             task.category is string && (task.category == 'Work' || task.category == 'Personal' || task.category == 'Education' || task.category == 'Health' || task.category == 'Shopping' || task.category == 'Finance' || task.category == 'Other' || (task.category.size() <= 50 && task.category.matches('^custom_[0-9]+$'))) &&
             task.completed is bool &&
             task.dueDate is timestamp &&
             (!task.keys().hasAll(['createdAt']) || task.createdAt is timestamp) &&
             (!task.keys().hasAll(['updatedAt']) || task.updatedAt is timestamp) &&
             (!task.keys().hasAll(['overdueEmailSent']) || task.overdueEmailSent is bool) &&
             (!task.keys().hasAll(['description']) || (task.description is string && task.description.size() <= 1000)) &&
             (!task.keys().hasAll(['project']) || (task.project == null || (task.project is string && task.project.size() <= 100))) &&
             (!task.keys().hasAll(['reminderTime']) || (task.reminderTime == null || task.reminderTime is timestamp)) &&
             (!task.keys().hasAll(['recurrence']) || (
               task.recurrence == null || (
                 task.recurrence is map &&
                 task.recurrence.frequency is string &&
                 (task.recurrence.frequency == 'none' || task.recurrence.frequency == 'daily' || task.recurrence.frequency == 'weekly' || task.recurrence.frequency == 'monthly' || task.recurrence.frequency == 'custom') &&
                 (!task.recurrence.keys().hasAll(['interval']) || task.recurrence.interval is int) &&
                 (!task.recurrence.keys().hasAll(['unit']) || (task.recurrence.unit is string && (task.recurrence.unit == 'days' || task.recurrence.unit == 'weeks' || task.recurrence.unit == 'months')))
               )
             ));
    }

    // 2. Fortress Rules for tasks collection
    match /tasks/{taskId} {
      allow get: if isVerifiedUser() && existing().userId == request.auth.uid && isValidId(taskId);
      
      allow list: if isVerifiedUser() && resource.data.userId == request.auth.uid;

      allow create: if isVerifiedUser() && 
                    isValidId(taskId) && 
                    isValidTask(incoming()) && 
                    incoming().createdAt == request.time && 
                    incoming().updatedAt == request.time;

      allow update: if isVerifiedUser() && 
                    isValidId(taskId) && 
                    existing().userId == request.auth.uid && 
                    incoming().userId == request.auth.uid && 
                    isValidTask(incoming()) && 
                    (!incoming().keys().hasAll(['createdAt']) || !existing().keys().hasAll(['createdAt']) || incoming().createdAt == existing().createdAt) && 
                    incoming().updatedAt == request.time;

      allow delete: if isVerifiedUser() && 
                    isValidId(taskId) && 
                    existing().userId == request.auth.uid;
    }

    // 3. Fortress Rules for settings collection
    match /settings/{userId} {
      allow get: if isVerifiedUser() && userId == request.auth.uid && isValidId(userId);
      allow create, update: if isVerifiedUser() && userId == request.auth.uid && isValidId(userId) && incoming().userId == request.auth.uid;
      allow delete: if isVerifiedUser() && userId == request.auth.uid && isValidId(userId);
    }
  }
}
